# Copy to .env.local and fill in values

# Google OAuth (NextAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# BigQuery — either a path to a service account JSON file,
# or the JSON content as a string (preferred on hosting platforms)
GOOGLE_APPLICATION_CREDENTIALS=
BIGQUERY_CREDENTIALS_JSON=

# HubSpot Private App token
# Required for live contact fetching on the company detail page.
# Create a Private App in HubSpot Settings → Integrations → Private Apps
# with scopes: crm.objects.contacts.read, crm.objects.companies.read
HUBSPOT_ACCESS_TOKEN=
